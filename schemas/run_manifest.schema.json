{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpcopt.local/schemas/run_manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "required": [
    "timestamp_utc",
    "command",
    "inputs",
    "outputs",
    "params"
  ],
  "properties": {
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "command": {
      "type": "string"
    },
    "git_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "python_version": {
      "type": "string"
    },
    "package_versions": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "policy_hash_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "dependency_lock_hash_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool_versions": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "config_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "seeds": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "manifest_hash_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "immutable": {
      "type": "boolean"
    },
    "params": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
