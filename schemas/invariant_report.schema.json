{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpcopt.local/schemas/invariant_report.schema.json",
  "title": "InvariantReport",
  "type": "object",
  "required": [
    "run_id",
    "strict_mode",
    "step_count",
    "violations"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "strict_mode": {
      "type": "boolean"
    },
    "step_count": {
      "type": "integer",
      "minimum": 0
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step_index",
          "event_type",
          "failed_invariants"
        ],
        "properties": {
          "step_index": {
            "type": "integer",
            "minimum": 0
          },
          "event_type": {
            "type": "string"
          },
          "clock_ts": {
            "type": [
              "integer",
              "null"
            ]
          },
          "failed_invariants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "type": [
              "string",
              "null"
            ]
          },
          "state_hash": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": true
}
